# ─── Ambiente ────────────────────────────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true

# ─── Banco de dados ──────────────────────────────────────────────────────────
# Docker: use DB_HOST=db (nome do serviço no docker-compose.yml)
# Servidor local: use DB_HOST=127.0.0.1 e ajuste a porta
DB_HOST=db
DB_PORT=3306
DB_DATABASE=helpit
DB_USERNAME=helpit_user
DB_PASSWORD=helpit_pass_2026

# ─── Chave de criptografia AES-256-GCM ───────────────────────────────────────
# Gere sua chave com: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=sua_chave_hex_de_64_caracteres_aqui
