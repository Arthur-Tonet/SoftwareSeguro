{
    "name": "grupo5/helpit-ra2",
    "description": "Sistema de chamados de TI com PHP seguro — Software Seguro RA2",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testdox"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
